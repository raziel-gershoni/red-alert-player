[Unit]
Description=Red Alert Player — Pikud HaOref monitor for חריש
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 /home/raziel/red_alert_player.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
